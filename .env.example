# Copy to .env and fill in. Never commit the real .env.
PORT=5000

# Payment provider — "paystack" or "daraja"
PAYMENT_PROVIDER=paystack

# --- Paystack (when PAYMENT_PROVIDER=paystack) ---
PAYSTACK_SECRET_KEY=
# PAYSTACK_EMAIL=owner@example.com

# --- Daraja / Safaricom M-Pesa (when PAYMENT_PROVIDER=daraja) ---
DARAJA_ENV=sandbox                        # sandbox | production
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline   # or CustomerBuyGoodsOnline
DARAJA_CALLBACK_URL=                      # https://yourdomain/api/webhook/daraja
DARAJA_ACCOUNT_REF=HOTSPOT

# --- UniFi Controller ---
UNIFI_URL="https://<controller-ip>:8443"
UNIFI_USERNAME="voucher"
UNIFI_PASSWORD=""
UNIFI_SITE=""
