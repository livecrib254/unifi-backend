# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000

# ─────────────────────────────────────────────────────────────
# Payment provider — choose ONE: "paystack" or "daraja"
# ─────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=paystack

# Dummy-payment test route POST /api/test-authorize (NON-PRODUCTION ONLY).
# Leave false/unset in production. Edit TEST_DEFAULTS in hotspotServer.js to set
# the MAC/duration to test with.
ENABLE_TEST_ROUTE=false

# ─────────────────────────────────────────────────────────────
# Paystack (used when PAYMENT_PROVIDER=paystack)
# ─────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=            # sk_test_... or sk_live_...
# PAYSTACK_EMAIL=owner@example.com   # optional fallback receipt email

# ─────────────────────────────────────────────────────────────
# Daraja / Safaricom M-Pesa (used when PAYMENT_PROVIDER=daraja)
# See PAYMENTS.md for how to obtain each value.
# ─────────────────────────────────────────────────────────────
DARAJA_ENV=sandbox                              # sandbox | production
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=                               # Paybill or Till number
DARAJA_PASSKEY=                                 # Lipa Na M-Pesa Online passkey
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline   # or CustomerBuyGoodsOnline for a Till
DARAJA_CALLBACK_URL=                            # https://yourdomain/api/webhook/daraja
DARAJA_ACCOUNT_REF=HOTSPOT                      # label on the paybill account field (max 12 chars)

# ─────────────────────────────────────────────────────────────
# UniFi Controller
# ─────────────────────────────────────────────────────────────
UNIFI_URL="https://<controller-ip>:8443"
UNIFI_USERNAME="voucher"
UNIFI_PASSWORD=""
UNIFI_SITE="<site-id>"
